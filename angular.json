{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "awnings-ireland": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css",
              "node_modules/quill/dist/quill.snow.css"
            ]
          },
          "configurations": {
            "production": {
               "fileReplacements": [
                {
                  "replace": "src/app/environments/environment.ts",
                  "with": "src/app/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "4MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "16kB",
                  "maximumError": "32kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "src/app/environments/environment.ts",
                  "with": "src/app/environments/environment.dev.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "local": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "client-awnings": {
              "index": "src/clients/awnings/index.html",
              "fileReplacements": [
                {
                  "replace": "src/app/environments/environment.ts",
                  "with": "src/app/environments/environment.awnings.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/clients/awnings/assets",
                  "output": "assets"
                }
              ],
              "outputHashing": "all"
            },
            "client-unnamed": {
              "index": "src/clients/unnamed/index.html",
              "fileReplacements": [
                {
                  "replace": "src/app/environments/environment.ts",
                  "with": "src/app/environments/environment.unnamed.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/clients/unnamed/assets",
                  "output": "assets"
                }
              ],
              "outputHashing": "all"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "awnings-ireland:build:production"
            },
            "development": {
              "buildTarget": "awnings-ireland:build:development"
            },
            "local": {
              "buildTarget": "awnings-ireland:build:local"
            },
            "client-awnings": {
              "buildTarget": "awnings-ireland:build:client-awnings"
            },
            "client-unnamed": {
              "buildTarget": "awnings-ireland:build:client-unnamed"
            }
          },
          "defaultConfiguration": "local"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "tsconfig.spec.json",
           "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*",
                "input": "public",
                "output": "./"
              }
            ],
            "styles": [
              "src/styles.css",
              "node_modules/quill/dist/quill.snow.css"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "dffa5f5b-e651-44f2-934a-42fa68957bd6"
  }
}
